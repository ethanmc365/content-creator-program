# ============================================================
# Tryp.com Creator Platform — environment variables
# Copy this file to .env and fill in both values.
# Find them in Supabase: Project Settings → API.
# ============================================================

# Your Supabase project URL, e.g. https://abcdefghijkl.supabase.co
VITE_SUPABASE_URL=

# Your Supabase "anon / public" API key (safe for the browser —
# row-level security is what protects the data, not this key).
VITE_SUPABASE_ANON_KEY=
